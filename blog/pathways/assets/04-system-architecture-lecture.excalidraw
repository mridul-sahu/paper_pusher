    {
      "type": "text",
      "id": "async_insight",
      "x": 100,
      "y": 860,
      "width": 650,
      "height": 50,
      "text": "Client runs ahead of TPUs. Returns Futures immediately. By the time the TPUs\nfinish Step 0, Steps 1 and 2 are already queued → TPUs never idle.",
